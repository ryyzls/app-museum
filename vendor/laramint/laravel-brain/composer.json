{
    "name": "laramint/laravel-brain",
    "description": "Visualize your Laravel request lifecycle as an interactive graph",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "nikic/php-parser": "^5.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "laramint/laravel-stress": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "laramint/laravel-security-scanner": "^0.1"
    },
    "suggest": {
        "laramint/laravel-security-scanner": "Install in your app (--dev) to replace Brain's built-in source security rules with the more rigorous taint-based scanner. Brain auto-detects vendor/bin/php-security-scanner and falls back to built-in rules if absent."
    },
    "autoload": {
        "psr-4": {
            "LaraMint\\LaravelBrain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraMint\\LaravelBrain\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "./vendor/bin/pint --parallel"
        ],
        "test:lint": [
            "./vendor/bin/pint --parallel --test"
        ],
        "test:unit": "./vendor/bin/pest --order-by=random",
        "test:types": "./vendor/bin/phpstan analyse --memory-limit 512M",
        "test": [
            "@test:lint",
            "@test:unit",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraMint\\LaravelBrain\\LaravelBrainServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
